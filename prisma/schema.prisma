generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  PAUSED
}

enum PreferredTime {
  MORNING
  EVENING
  BOTH
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WarmupGoal {
  PRE_WORKOUT
  DESK_RESET
  RECOVERY
  FLEXIBILITY
}

enum RestrictionLevel {
  NONE
  GENTLE_ONLY
  PAIN_OR_INJURY
}

enum VideoType {
  WARMUP
  MOBILITY
  STRETCH
  RECOVERY
}

enum VideoIntensity {
  LOW
  MEDIUM
  HIGH
}

enum RitualType {
  MORNING
  EVENING
}

enum RitualSessionStatus {
  STARTED
  COMPLETED
  ABANDONED
}

enum DailyStatusType {
  COMPLETED
  MISSED
  REST
}

model User {
  id              String           @id @default(cuid())
  email           String?          @unique
  authProvider    String?
  authProviderAccountId String?
  displayName     String
  avatarUrl       String?
  timezone        String           @default("UTC")
  locale          String           @default("en")
  status          UserStatus       @default(ACTIVE)
  onboardingCompleted Boolean      @default(false)
  xpTotal         Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profile         UserProfile?
  progress        UserProgress?
  ritualSessions  RitualSession[]
  dailyStatuses   DailyStatus[]

  @@unique([authProvider, authProviderAccountId])
}

model UserProfile {
  userId            String         @id
  goal              String?
  preferredTime     PreferredTime  @default(MORNING)
  fitnessLevel      FitnessLevel   @default(BEGINNER)
  warmupGoal        WarmupGoal?
  focusAreas        String[]       @default([])
  timeBudgetMinutes Int?
  restrictionLevel  RestrictionLevel?
  experiencePoints  Int            @default(0)
  currentLevel      Int            @default(1)
  currentStreak     Int            @default(0)
  longestStreak     Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProgress {
  userId                  String    @id
  level                   Int       @default(1)
  xp                      Int       @default(0)
  streak                  Int       @default(0)
  rankPosition            Int?
  totalCompletedSessions  Int       @default(0)
  weeklyCompletedSessions Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ritual {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  type             RitualType
  description      String?
  durationMinutes  Int
  xpReward         Int             @default(25)
  isActive         Boolean         @default(true)
  isPublished      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  exercises        Exercise[]
  audioTracks      AudioTrack[]
  ritualSessions   RitualSession[]
}

model Exercise {
  id               String    @id @default(cuid())
  ritualId         String
  title            String
  description      String?
  durationSeconds  Int
  orderIndex       Int
  audioCue         String?
  illustrationUrl  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ritual           Ritual    @relation(fields: [ritualId], references: [id], onDelete: Cascade)

  @@unique([ritualId, orderIndex])
}

model AudioTrack {
  id               String    @id @default(cuid())
  ritualId         String
  title            String
  fileUrl          String?
  durationSeconds  Int
  language         String    @default("ru")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ritual           Ritual    @relation(fields: [ritualId], references: [id], onDelete: Cascade)
}

model RitualSession {
  id                String               @id @default(cuid())
  status            RitualSessionStatus  @default(STARTED)
  startedAt         DateTime?
  completedAt       DateTime?
  completedPercent  Int                  @default(0)
  earnedXp          Int                  @default(0)
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  ritualId          String
  ritual            Ritual               @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ritualId, status])
}

model DailyStatus {
  id          String           @id @default(cuid())
  userId      String
  date        DateTime
  ritualType  RitualType
  status      DailyStatusType
  sessionId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, ritualType])
  @@index([userId, date])
}

model Video {
  id             String                @id @default(cuid())
  slug           String                @unique
  title          String
  description    String?
  videoUrl       String
  thumbnailUrl   String?
  durationSec    Int
  level          FitnessLevel
  type           VideoType
  goalTags       WarmupGoal[]
  focusTags      String[]
  safetyTags     String[]              @default([])
  contextTags    String[]              @default([])
  intensity      VideoIntensity
  isPublished    Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}
